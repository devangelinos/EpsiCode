@model IEnumerable<EpsiCodeWeb.Models.OrderViewModel>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Order Management</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createOrderModal">
            <i class="bi bi-plus-circle"></i> Create New Order
        </button>
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Order ID</th>
                <th>Address</th>
                <th>Date</th>
                <th>Total Cost</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model.OrderByDescending(o => o.CreationDate))
            {
                <tr>
                    <td class="text-muted small">@order.Id.ToString().Substring(0, 8)...</td>
                    <td>@order.Address</td>
                    <td>@order.CreationDate.ToString("MMM dd, yyyy HH:mm")</td>
                    <td><strong>$@order.TotalCost.ToString("F2")</strong></td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-info btn-sm">
                            Manage Items
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="modal fade" id="createOrderModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="Create" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">New Order</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Shipping Address</label>
                        <input type="text" name="address" class="form-control" placeholder="Enter full address" required />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save & Add Books</button>
                </div>
            </form>
        </div>
    </div>
</div>